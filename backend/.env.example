# ============================================================
# DentGrow Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# JWT Secret — generate a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Supabase — get these from supabase.com > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# WhatsApp (Meta Cloud API) — get from developers.facebook.com
# Leave empty to use mock mode (messages logged to console)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Resend (email) — get from resend.com
# Leave empty to use mock mode (emails logged to console)
RESEND_API_KEY=
EMAIL_FROM=noreply@dentgrow.in

# Razorpay — get from razorpay.com
# Leave empty to skip payment features
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
